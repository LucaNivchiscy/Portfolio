---
interface Props {
    date: string;
    title: string;
    description: string;
    link?: string;
}
const {date, title, description, link} = Astro.props;
---
 
 <div class="absolute w-3 h-3 bg-cyan-400 rounded-full mt-1.5 -start-1.5 border border-gray-900"></div>
    <time class="mb-1 text-xs font-normal leading-none text-violet-300">
            {date}
        </time>
    <h3 class="text-xl font-semibold text-white">
            {title}
        </h3>
    <p class="mb-4 text-base font-normal text-gray-300 text-pretty">
            {description}
        </p>
        {
            link && (
                <a href={link} class="inline-flex items-center px-4 py-2 text-sm font-medium text-cyan-400 border border-cyan-400 rounded-lg hover:bg-cyan-400 hover:text-black focus:z-10 focus:ring-4 focus:outline-none focus:ring-cyan-900 transition-colors duration-300">
                    Saber más...
                    <svg class="w-3 h-3 ms-2 rtl:rotate-180" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
                    </svg>
                </a>
            )
        }
        